@using NF.Common.Utility;
@using NF.ViewModel.Models;
@using NF.Model.Models;
@model APPWFLayPageInfo<CompanyViewDTO>;
@{
    ViewData["Title"] = "CustomerDetails";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<html>
<head runat="server">
    <title>客户审批</title>
    <link href="~/css/DetailsPage.css" type="text/css" rel="stylesheet" />
    <meta name="format-detection" content="telephone=no" />
</head>
<body>
    <form id="form1" runat="server">
        <div class="TopTitle">
            <h1 style="text-align: center;"><strong style="border-bottom-style: double; border-color: red">客 户 审 批</strong></h1>
        </div>
        @*客户信息*@
        <table border="0" cellpadding="0" cellspacing="0">
            <tr>
                <td colspan="4" class="TopTb">客户信息</td>
            </tr>
            <tr>
                <td class="ConInfoId" id="contractNameTD">客户名称</td>
                <td colspan="3">@Model.WFInstanceList[0].Name</td>
            </tr>
            <tr>
                <td class="ConInfoId">客户编号</td>
                <td class="ConInfoText">@Model.WFInstanceList[0].Code</td>
                <td class="ConInfoId">客户类别</td>
                <td class="ConInfoText">@Model.WFInstanceList[0].CompanyTypeClass</td>
            </tr>
            <tr>
                <td class="ConInfoId">客户行业</td>
                <td class="ConInfoText">@Model.WFInstanceList[0].Trade</td>
                <td class="ConInfoId">负责人</td>
                <td class="ConInfoText"></td>
            </tr>
            <tr>
                <td class="ConInfoId">创建人</td>
                <td class="ConInfoText">@Model.WFInstanceList[0].CreateUserDisplayName</td>
                <td class="ConInfoId">创建时间</td>
                <td class="ConInfoText">@Model.WFInstanceList[0].CreateDateTime</td>
            </tr>
        </table>
        <br />
        @{
            Html.RenderPartial("_ShenpiDetails");
        }
    </form>
</body>
</html>


