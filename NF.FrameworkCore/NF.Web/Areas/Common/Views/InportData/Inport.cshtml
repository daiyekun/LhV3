
@{
    ViewData["Title"] = "Inport";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- 让IE8/9支持媒体查询，从而兼容栅格 -->
<!--[if lt IE 9]>
  <script src="https://cdn.staticfile.org/html5shiv/r29/html5.min.js"></script>
  <script src="https://cdn.staticfile.org/respond.js/1.4.2/respond.min.js"></script>
<![endif]-->
<div class="layui-fluid">
    <div class="layui-card ">
        <div class="layui-card-header">导入基本数据</div>
        <div class="layui-card-body" style="padding: 15px;">
            <div class="layui-form" lay-filter="UplodadForm">
                <blockquote class="layui-elem-quote">导入顺序：项目|合同对方->合同->其他</blockquote>
                <div class="layui-inline">
                    <label class="layui-form-label">导入主体</label>
                    <div class="layui-input-inline">
                        <select name="SelType" id="SelType" lay-verify="required">
                            <option value="0">请选择导入主体</option>
                            <option value="1">合同对方</option>
                            <option value="2">合同</option>
                            <option value="3">项目</option>
                            <option value="4">计划资金</option>
                            <option value="5">实际资金</option>
                            <option value="6">发票</option>
                            <option value="7">标的</option>
                            <option value="8">用户</option>
                        </select>
                    </div>
                </div>
                <div class=" layui-input-inline">
                    <button type="button" class="layui-btn layui-btn-normal" id="selField">选择文件</button>
                    <button type="button" class="layui-btn" id="btnUpload">开始上传</button>
                </div>
            </div>
            <br />
            <blockquote class="layui-elem-quote">文件列表：</blockquote>
            <div>
                <table id="NF-InportData-Index" lay-filter="NF-InportData-Index"></table>
                <script type="text/html" id="table-inpData-bar">
                    <a class="layui-btn layui-btn-normal layui-btn-xs" lay-event="inportData"><i class="layui-icon layui-icon-edit"></i>导入</a>
                    <a class="layui-btn layui-btn-danger layui-btn-xs" lay-event="del"><i class="layui-icon layui-icon-delete"></i>删除</a>
                </script>
            </div>
        </div>
    </div>
</div>
<script src="~/lib/layuiadmin/layui/layui.js" type="text/javascript"></script>
<script type="text/javascript">
    layui.config({
        base: '/lib/layuiadmin/' //静态资源所在路径
    }).extend({
            index: 'lib/index' //主入口模块
    }).use(['index', 'element', 'upload', 'table'], function () {
               var $ = layui.$
              ,element=layui.element
              , layer = layui.layer
               , admin = layui.admin
              , setter = layui.setter
              , upload = layui.upload
              , table = layui.table;
               //var logdindex = layer.load(0, { shade: false });
        var _url = setter.layupload.uploadIp + '/Common/InportData/Upload?Dtype=-1';
        //layer.alert(_url);
        var logdindex = 0;
        upload.render({
        elem: '#selField'
       , url: _url
       , auto: false
       , accept: 'file' //普通文件
       , exts: 'xlsx'
       , bindAction: '#btnUpload'
       , before: function (obj) {
           var sel = $("#SelType").val();
           if (sel === "0") {
               layer.alert("请选择导入主体");
           } else {
               logdindex = layer.load(0, { shade: false });
           }


       }
       ,done: function (res)
       {
           layer.close(logdindex);

           admin.req({
               url: '/Common/InportData/SaveFile',
               data: {
                     GfName: res.Data.GuidFileName
                   , SfName: res.Data.SourceFileName
                    ,SelType:$("#SelType").val()
                   , rand: wooutil.getRandom()
               },
               done: function (res) {
                   table.reload("NF-InportData-Index", {
                       where: { rand: wooutil.getRandom() }

                   });
                   layer.alert("上传成功！");

               }
           });

       }
        });

        /***
        **列表
        ****/
        table.render({
        elem: '#NF-InportData-Index'
            , url: "/Common/InportData/GetFiles"
       , toolbar: false
       , defaultToolbar: ['filter']
       , cellMinWidth: 80
       , cols: [[
             { type: 'numbers', fixed: 'left' }
           , { field: 'GfName', title: '名称', width: 300 }
           , { field: 'SfName', title: '原始文件名称', width: 220 }
           , { field: 'SelTypeDic', title: '导入主体', width: 160 }
           , { title: '操作', width: 150, align: 'center', fixed: 'right', toolbar: '#table-inpData-bar' }
       ]]
      // , page: true
       , loading: true
       , height: 300
       , limit: setter.table.limit
       , limits: setter.table.limits
       , done: function (res, curr, count) {   //返回数据执行回调函数

       } });


        /**工具栏***/

        table.on('tool(NF-InportData-Index)', function (obj) {

            switch (obj.event) {
                case "del":
                    {
                        admin.req({
                            url: '/Common/InportData/DelFile',
                            data: {
                                GfName: obj.data.GfName

                                , rand: wooutil.getRandom()
                            },
                            done: function (res) {
                                table.reload("NF-InportData-Index", {
                                    where: { rand: wooutil.getRandom() }

                                });
                                layer.alert("删除成功！");

                            }
                        });
                    }
                    break;

                case "inportData"://导入
                    {
                        admin.req({
                            url: '/Common/InportData/InportData',
                            data: {
                                GfName: obj.data.GfName
                                , InportType: obj.data.SelType
                                , rand: wooutil.getRandom()
                            },
                            done: function (res) {
                                //table.reload("NF-InportData-Index", {
                                //    where: { rand: wooutil.getRandom() }

                                //});
                                layer.alert("执行完毕！");

                            }
                        });
                    }
                    break;
            }
        });


    });

</script>

